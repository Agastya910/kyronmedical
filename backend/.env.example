# ── Low-Latency LLM for Voice ────────────────────────────
# We highly recommend Groq for real-time voice latency (llama-3.3-70b-versatile)
GROQ_API_KEY=your_groq_api_key

# Fallback 1: OpenRouter (for moonshotai/kimi-k2:free)
# OPENROUTER_API_KEY=your_openrouter_api_key

# Fallback 2: Ollama (local or cloud-hosted)
# OLLAMA_BASE_URL=https://ollama.com/v1
# OLLAMA_API_KEY=ollama
# OLLAMA_MODEL=deepseek-v3.1:671b-cloud

# ── Vapi ─────────────────────────────────────────────────
VAPI_API_KEY=your_vapi_private_key
VAPI_PUBLIC_KEY=your_vapi_public_key
VAPI_PHONE_ASSISTANT_ID=your_phone_assistant_id
VAPI_INBOUND_ASSISTANT_ID=your_inbound_assistant_id
VAPI_PHONE_NUMBER_ID=your_phone_number_id

# ── Notifications ─────────────────────────────────────────
SENDGRID_API_KEY=SG.your_key
SENDGRID_FROM_EMAIL=care@kyronmedical.com
TWILIO_ACCOUNT_SID=ACxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
OPENAI_API_KEY=sk-...
SERVER_BASE_URL=https://yourdomain.com
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── App ───────────────────────────────────────────────────
APP_ENV=development
FRONTEND_URL=http://localhost:3000
