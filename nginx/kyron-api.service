[Unit]
Description=Kyron Medical FastAPI Backend
After=network.target redis.service

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/kyron-medical/backend
ExecStart=/home/ubuntu/kyron-medical/backend/.venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000 --workers 2
Restart=on-failure
RestartSec=5
EnvironmentFile=/home/ubuntu/kyron-medical/backend/.env

[Install]
WantedBy=multi-user.target
